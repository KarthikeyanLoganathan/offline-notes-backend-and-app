### Labels Endpoints

@baseUrl = http://localhost:3000
@contentType = application/json
@authToken = your-jwt-token-here
@labelId = 1

### Create a new label
POST {{baseUrl}}/api/labels
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "name": "Work",
  "color": "#FF5733"
}

### Create another label
POST {{baseUrl}}/api/labels
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "name": "Personal",
  "color": "#33FF57"
}

### Create label - Shopping
POST {{baseUrl}}/api/labels
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "name": "Shopping",
  "color": "#3357FF"
}

### Create label - Important
POST {{baseUrl}}/api/labels
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "name": "Important",
  "color": "#FF3333"
}

### Create label - Ideas
POST {{baseUrl}}/api/labels
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "name": "Ideas",
  "color": "#FFFF33"
}

### Get all labels
GET {{baseUrl}}/api/labels
Authorization: Bearer {{authToken}}

### Get single label
GET {{baseUrl}}/api/labels/{{labelId}}
Authorization: Bearer {{authToken}}

### Update label
PUT {{baseUrl}}/api/labels/{{labelId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "name": "Work Updated",
  "color": "#FF6347"
}

### Update label - name only
PUT {{baseUrl}}/api/labels/{{labelId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "name": "Professional"
}

### Update label - color only
PUT {{baseUrl}}/api/labels/{{labelId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "color": "#4169E1"
}

### Delete label
DELETE {{baseUrl}}/api/labels/{{labelId}}
Authorization: Bearer {{authToken}}

### Try to create duplicate label (should fail)
POST {{baseUrl}}/api/labels
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "name": "Work",
  "color": "#FF5733"
}
